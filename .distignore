# Files excluded from the wp.org build. This plugin is self-contained: it has no
# runtime Composer dependencies, so /vendor is dev-only and excluded from the zip.
/vendor
/.git
/.github
/.gitignore
/.distignore
/.wp-env.json
/.wp-env.override.json
/node_modules
/tests
/scripts
/docs
/composer.json
/composer.lock
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpstan-baseline.neon
/playwright.config.ts
/tsconfig.json
/vite.config.ts
/README.md
/SPEC.md
/.DS_Store

.DS_Store
/.wordpress-org
/test-results
/playwright-report
/.playwright-mcp
