#. Plugin Name of the plugin
#: tipping.php
msgid "Tipping - Checkout Tips and Donations for WooCommerce"
msgstr "Tipping - Napiwki i darowizny przy zamówieniu dla WooCommerce"

#. Plugin URI of the plugin
#: tipping.php
msgid "https://plogins.com/tipping/"
msgstr "https://plogins.com/tipping/"

#. Description of the plugin
#: tipping.php
msgid "Let customers add an optional tip or donation at checkout."
msgstr "Pozwól klientom dodać opcjonalny napiwek lub darowiznę przy składaniu zamówienia."

#. Author of the plugin
#: tipping.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: tipping.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: src/Admin/Settings.php:52
#: src/Admin/Settings.php:53
msgid "Tipping"
msgstr "Napiwki"

#: src/Admin/Settings.php:92
msgid "Let customers add a tip or donation at checkout"
msgstr "Pozwól klientom dodać napiwek lub darowiznę przy składaniu zamówienia"

#: src/Admin/Settings.php:94
msgid "A friendly, optional tip control on the checkout. Pick preset amounts — fixed or a percentage of the order — and the tip is added to the order totals as a fee. Updates live as the customer chooses."
msgstr "Przyjazny, opcjonalny element do pozostawienia napiwku przy zamówieniu. Wybierz predefiniowane kwoty — stałe lub procentowe od wartości zamówienia — a napiwek zostanie dodany do podsumowania zamówienia jako opłata. Wartość aktualizuje się na bieżąco podczas wyboru przez klienta."

#: src/Admin/Settings.php:102
msgid "General"
msgstr "Ogólne"

#: src/Admin/Settings.php:106
msgid "Enable tipping"
msgstr "Włącz napiwki"

#: src/Admin/Settings.php:110
msgid "Show the tip control on the checkout."
msgstr "Wyświetlaj element napiwku przy składaniu zamówienia."

#: src/Admin/Settings.php:112
msgid "When off, the control never renders and no assets load on the storefront."
msgstr "Po wyłączeniu element nigdy się nie wyświetla i żadne zasoby nie są ładowane w sklepie."

#: src/Admin/Settings.php:117
msgid "Label"
msgstr "Etykieta"

#: src/Admin/Settings.php:120
#: src/Settings/Options.php:64
msgid "Add a tip"
msgstr "Dodaj napiwek"

#: src/Admin/Settings.php:121
msgid "The heading shown above the tip buttons, e.g. “Add a tip” or “Support our shelter”."
msgstr "Nagłówek wyświetlany nad przyciskami napiwku, np. „Dodaj napiwek” lub „Wesprzyj nasze schronisko”."

#: src/Admin/Settings.php:126
msgid "Description"
msgstr "Opis"

#: src/Admin/Settings.php:130
msgid "Optional supporting text shown under the label. Tipping is always optional for the customer."
msgstr "Opcjonalny tekst uzupełniający wyświetlany pod etykietą. Napiwek jest zawsze dobrowolny dla klienta."

#: src/Admin/Settings.php:138
msgid "Presets"
msgstr "Wartości predefiniowane"

#: src/Admin/Settings.php:143
msgid "Preset type"
msgstr "Typ wartości predefiniowanej"

#: src/Admin/Settings.php:147
msgid "Percentage of cart"
msgstr "Procent wartości koszyka"

#: src/Admin/Settings.php:148
msgid "Fixed amount"
msgstr "Kwota stała"

#: src/Admin/Settings.php:150
msgid "Percentage presets scale with the order total (5% of the subtotal). Fixed presets are flat amounts in your store currency."
msgstr "Wartości procentowe skalują się wraz z wartością zamówienia (5% wartości koszyka). Wartości stałe to kwoty ryczałtowe w walucie Twojego sklepu."

#: src/Admin/Settings.php:155
msgid "Preset values"
msgstr "Wartości predefiniowane"

#: src/Admin/Settings.php:159
msgid "Comma-separated values. For percentages use whole numbers (5, 10, 15); for fixed amounts use currency values (2, 5, 10). Up to a handful keeps the control tidy."
msgstr "Wartości oddzielone przecinkami. Dla procentów użyj liczb całkowitych (5, 10, 15); dla kwot stałych użyj wartości pieniężnych (2, 5, 10). Kilka wartości sprawia, że element pozostaje przejrzysty."

#. translators: %s: a whole-number percentage, e.g. 10.
#: src/Frontend/TipControl.php:108
#, php-format
msgid "%s%%"
msgstr "%s%%"

#: templates/tip-control.php:38
msgid "No tip"
msgstr "Bez napiwku"

#: tipping.php:47
msgid "Tipping - Checkout Tips and Donations for WooCommerce requires WooCommerce to be active."
msgstr "Tipping - Napiwki i darowizny przy zamówieniu dla WooCommerce wymaga aktywnej wtyczki WooCommerce."
